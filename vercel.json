{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src * 'unsafe-inline' 'unsafe-eval' data: blob:; script-src * 'unsafe-inline' 'unsafe-eval'; style-src * 'unsafe-inline'; frame-src *; connect-src *;"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/(.*)acscdn.com/(.*)", "destination": "/404" },
    { "source": "/(.*)ads.tiogolhd.com/(.*)", "destination": "/404" },
    { "source": "/(.*)bvtpk.com/(.*)", "destination": "/404" },
    { "source": "/(.*)waust.at/(.*)", "destination": "/404" },
    { "source": "/(.*)googletagmanager.com/(.*)", "destination": "/404" },
    { "source": "/(.*)jnbhi.com/(.*)", "destination": "/404" },
    { "source": "/(.*)deepz.cyou/(.*)", "destination": "/404" }
  ]
}
